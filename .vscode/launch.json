{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "gui",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/packages/nomad-FAIR/gui"
    },
    {
      "name": "app",
      "type": "python",
      "request": "launch",
      "justMyCode": false,
      "program": "${workspaceFolder}/.venv/bin/nomad",
      "args": ["admin", "run", "app"]
    },
    {
      "name": "worker",
      "type": "python",
      "request": "launch",
      "justMyCode": false,
      "program": "${workspaceFolder}/.venv/bin/nomad",
      "args": ["admin", "run", "worker"]
    },
    {
      "name": "hub",
      "type": "python",
      "request": "launch",
      "justMyCode": false,
      "program": "${workspaceFolder}/.venv/bin/nomad",
      "args": ["admin", "run", "hub"]
    },
    {
      "name": "nomad lab tests",
      "type": "python",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "module": "pytest",
      "args": ["-sv", "packages/nomad-FAIR/tests"]
    },
    {
      "name": "nomad parse",
      "type": "python",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/.venv/bin/nomad",
      "justMyCode": false,
      "args": [
        "parse",
        "--show-archive",
        "/home/nathan/Downloads/nomad_test_data/vasp_example/size_1/vasprun.xml"
      ]
    },
    {
      "name": "nomad test parser",
      "type": "python",
      "request": "launch",
      "purpose": ["debug-test"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "module": "pytest",
      "args": [
        "-sv",
        "--rootdir=${workspaceFolder}",
        "packages/nomad-parser-plugins-simulation/tests/parsers/test_vasp_parser.py"
      ]
    },
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "justMyCode": true
    },
    {
      "name": "Python: Debug Single Test",
      "type": "python",
      "request": "launch",
      "purpose": ["debug-test"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "module": "pytest",
      "args": [
        "-sv",
        "${file}::${selectedText}"
      ]
    },
    {
      "name": "Python: Attach",
      "type": "python",
      "request": "attach",
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "${workspaceFolder}",
      "port": 3000,
      "secret": "my_secret",
      "host": "localhost"
    }
  ]
}
